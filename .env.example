# Copier ce fichier en .env et remplir les clés

# Clé API Gemini (GRATUIT) — https://aistudio.google.com/
# 1. Connecte-toi avec ton compte Google
# 2. Clique sur "Get API Key" → "Create API Key"
# 3. Copie la clé
GEMINI_API_KEY=...

# Clé API The Odds API — https://the-odds-api.com/ (plan gratuit: 500 req/mois)
ODDS_API_KEY=...

# Clé API-Football — optionnel, améliore la qualité des données
# https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=...

# Bot Telegram — rapport hebdomadaire (dimanche 20h00)
# 1. Ouvre Telegram → cherche @BotFather → /newbot → copie le token
# 2. Envoie un message à ton bot → va sur https://api.telegram.org/bot<TOKEN>/getUpdates → copie le chat_id
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...
